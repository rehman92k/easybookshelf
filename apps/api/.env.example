# API
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Database (Module M3)
DATABASE_URL=postgresql://easybookshelf:easybookshelf@localhost:5432/easybookshelf

# Redis (Module M2)
REDIS_URL=redis://localhost:6379

# JWT (Module M4)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_DAYS=30

# Firebase Auth (Module M4) — Option A (recommended): path to downloaded JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: individual env vars (use \n for line breaks in private key)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Firebase Web (client) — copy to apps/web-reader/.env.local
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Razorpay (Module M11)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Set to true to allow mock-pay endpoint when Razorpay keys are configured (dev only)
ALLOW_MOCK_PAYMENTS=false

# AWS S3 (optional — omit when using Firebase Storage in production)
STORAGE_DRIVER=local
# STORAGE_DRIVER=firebase
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_LOCAL_PATH=./storage

# Mobile OTP — codes are logged to the API console when PHONE_OTP_DEV_MODE=true
PHONE_OTP_DEV_MODE=true
PHONE_OTP_DEV_CODE=123456
PHONE_OTP_EXPIRES_MINUTES=10
# SMS_API_KEY=
# EMAIL_API_KEY=

# Dev super admin bootstrap (pnpm dev:create-super-admin) — phone required for SMS OTP
# SUPER_ADMIN_EMAIL=rahmanswords@gmail.com
# SUPER_ADMIN_PASSWORD=Admin4123
# SUPER_ADMIN_PHONE=9876543210
