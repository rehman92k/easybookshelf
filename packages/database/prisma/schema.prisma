generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  active
  suspended
  deleted
}

enum UserRoleType {
  reader
  author
  publisher
  publisher_staff
  admin_content
  admin_finance
  super_admin
}

enum RoleScopeType {
  global
  publisher
}

enum PublisherType {
  publisher
  author
}

enum PublisherStatus {
  pending
  approved
  suspended
}

enum BookFormat {
  epub
  pdf
  both
}

enum BookStatus {
  draft
  pending_review
  approved
  rejected
  archived
}

enum BookFileFormat {
  epub
  pdf
}

enum ProcessingStatus {
  pending
  processing
  ready
  failed
}

enum OrderItemType {
  purchase
  rental
  rental_15
  rental_30
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
}

enum EntitlementType {
  purchase
  rental
}

enum EntitlementStatus {
  active
  expired
  revoked
}

enum PaymentStatus {
  created
  authorized
  captured
  failed
  refunded
}

enum AnnotationType {
  bookmark
  highlight
  note
}

enum SubscriptionInterval {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  past_due
}

enum SettlementStatus {
  pending
  processing
  paid
}

enum AdPlacementType {
  homepage_banner
  search_native
  book_detail_sidebar
  reader_interstitial
  library_footer
}

enum OtpChannel {
  phone
  email
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id          String     @id @default(uuid()) @db.Uuid
  firebaseUid String?    @unique @map("firebase_uid")
  email       String?    @unique
  phone       String?    @unique
  displayName String     @map("display_name")
  avatarUrl   String?    @map("avatar_url")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  status      UserStatus @default(active)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  roles            UserRole[]
  sessions         Session[]
  otpChallenges    OtpChallenge[]
  publisher        Publisher?
  entitlements     Entitlement[]
  orders           Order[]
  readingProgress  ReadingProgress[]
  annotations      Annotation[]
  wishlists        Wishlist[]
  subscriptions    Subscription[]
  auditLogs        AuditLog[]        @relation("AuditActor")

  @@map("users")
}

model UserRole {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        UserRoleType
  scopeType   RoleScopeType @default(global) @map("scope_type")
  scopeId     String?       @map("scope_id") @db.Uuid
  permissions Json          @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, scopeType, scopeId])
  @@map("user_roles")
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  deviceFingerprint String?   @map("device_fingerprint")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model OtpChallenge {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  channel     OtpChannel
  destination String
  codeHash    String     @map("code_hash")
  attempts    Int        @default(0)
  expiresAt   DateTime   @map("expires_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_challenges")
}

// ─── Publishers & Authors ────────────────────────────────────────────────────

model Publisher {
  id                   String          @id @default(uuid()) @db.Uuid
  userId               String          @unique @map("user_id") @db.Uuid
  type                 PublisherType
  name                 String
  slug                 String          @unique
  description          String?
  addressLine          String?         @map("address_line")
  state                String?
  country              String?
  pincode              String?
  logoUrl              String?         @map("logo_url")
  taxId                String?         @map("tax_id")
  bankDetailsEncrypted Bytes?          @map("bank_details_encrypted")
  status               PublisherStatus @default(pending)
  commissionRate       Decimal?        @map("commission_rate") @db.Decimal(5, 4)
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  books                Book[]
  orderItems           OrderItem[]
  settlements          Settlement[]
  commissionHistory    CommissionRateHistory[]

  @@map("publishers")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  parentId    String?  @map("parent_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  parent   Category?      @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]     @relation("CategoryTree")
  books    BookCategory[]

  @@map("categories")
}

model Language {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  nativeName String  @map("native_name")
  rtl       Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  books BookLanguage[]

  @@map("languages")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  books BookTag[]

  @@map("tags")
}

model Book {
  id                 String     @id @default(uuid()) @db.Uuid
  publisherId        String     @map("publisher_id") @db.Uuid
  title              String
  subtitle           String?
  slug               String     @unique
  description        String?
  isbn               String?
  authorName         String     @map("author_name")
  coverImageUrl      String?    @map("cover_image_url")
  format             BookFormat
  previewPageCount   Int        @default(0) @map("preview_page_count")
  previewChapterCount Int       @default(0) @map("preview_chapter_count")
  status             BookStatus @default(draft)
  rejectionReason    String?    @map("rejection_reason")
  featured           Boolean    @default(false)
  publishedAt        DateTime?  @map("published_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  publisher       Publisher        @relation(fields: [publisherId], references: [id])
  prices          BookPrice[]
  files           BookFile[]
  categories      BookCategory[]
  languages       BookLanguage[]
  tags            BookTag[]
  orderItems      OrderItem[]
  entitlements    Entitlement[]
  readingProgress ReadingProgress[]
  annotations     Annotation[]
  wishlists       Wishlist[]

  @@index([publisherId])
  @@index([status])
  @@map("books")
}

model BookPrice {
  id            String   @id @default(uuid()) @db.Uuid
  bookId        String   @map("book_id") @db.Uuid
  purchasePrice Decimal  @map("purchase_price") @db.Decimal(10, 2)
  rental15Price Decimal  @map("rental_15_price") @db.Decimal(10, 2)
  rental30Price Decimal  @map("rental_30_price") @db.Decimal(10, 2)
  currency      String   @default("INR")
  effectiveFrom DateTime @default(now()) @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_prices")
}

model BookFile {
  id               String           @id @default(uuid()) @db.Uuid
  bookId           String           @map("book_id") @db.Uuid
  format           BookFileFormat
  s3KeyOriginal    String           @map("s3_key_original")
  s3KeyProcessed   String?          @map("s3_key_processed")
  fileSizeBytes    BigInt?          @map("file_size_bytes")
  pageCount        Int?             @map("page_count")
  spineItemCount   Int?             @map("spine_item_count")
  processingStatus ProcessingStatus @default(pending) @map("processing_status")
  checksumSha256   String?          @map("checksum_sha256")
  createdAt        DateTime         @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("book_files")
}

model BookCategory {
  bookId     String @map("book_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookId, categoryId])
  @@map("book_categories")
}

model BookLanguage {
  bookId     String @map("book_id") @db.Uuid
  languageId String @map("language_id") @db.Uuid

  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([bookId, languageId])
  @@map("book_languages")
}

model BookTag {
  bookId String @map("book_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookId, tagId])
  @@map("book_tags")
}

// ─── Commerce ────────────────────────────────────────────────────────────────

model Order {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  orderNumber String      @unique @map("order_number")
  totalAmount Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency    String      @default("INR")
  status      OrderStatus @default(pending)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
  payment Payment?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                 String        @id @default(uuid()) @db.Uuid
  orderId            String        @map("order_id") @db.Uuid
  bookId             String        @map("book_id") @db.Uuid
  publisherId        String        @map("publisher_id") @db.Uuid
  type               OrderItemType
  rentalDays         Int?          @map("rental_days")
  listUnitPrice      Decimal       @map("list_unit_price") @db.Decimal(10, 2)
  unitPrice          Decimal       @map("unit_price") @db.Decimal(10, 2)
  memberDiscountAmount Decimal     @default(0) @map("member_discount_amount") @db.Decimal(10, 2)
  commissionRate     Decimal       @map("commission_rate") @db.Decimal(5, 4)
  platformCommission Decimal       @map("platform_commission") @db.Decimal(10, 2)
  publisherAmount    Decimal       @map("publisher_amount") @db.Decimal(10, 2)
  createdAt          DateTime      @default(now()) @map("created_at")

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book        Book         @relation(fields: [bookId], references: [id])
  publisher   Publisher    @relation(fields: [publisherId], references: [id])
  entitlement Entitlement?
  settlementId String?      @map("settlement_id") @db.Uuid
  settlement   Settlement?  @relation(fields: [settlementId], references: [id])

  @@index([orderId])
  @@index([publisherId])
  @@index([settlementId])
  @@map("order_items")
}

model Entitlement {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  bookId      String            @map("book_id") @db.Uuid
  orderItemId String            @unique @map("order_item_id") @db.Uuid
  type        EntitlementType
  status      EntitlementStatus @default(active)
  startsAt    DateTime          @default(now()) @map("starts_at")
  expiresAt   DateTime?         @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book      @relation(fields: [bookId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@index([userId, bookId])
  @@map("entitlements")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @unique @map("order_id") @db.Uuid
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(created)
  method            String?
  rawResponse       Json?         @map("raw_response")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Reading ─────────────────────────────────────────────────────────────────

model ReadingProgress {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  bookId          String         @map("book_id") @db.Uuid
  format          BookFileFormat
  position        Json
  progressPercent Decimal        @default(0) @map("progress_percent") @db.Decimal(5, 2)
  lastReadAt      DateTime       @default(now()) @map("last_read_at")
  deviceId        String?        @map("device_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("reading_progress")
}

model Annotation {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  bookId          String         @map("book_id") @db.Uuid
  type            AnnotationType
  position        Json
  highlightedText String?        @map("highlighted_text")
  noteText        String?        @map("note_text")
  color           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, bookId])
  @@map("annotations")
}

model Wishlist {
  userId  String   @map("user_id") @db.Uuid
  bookId  String   @map("book_id") @db.Uuid
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([userId, bookId])
  @@map("wishlists")
}

// ─── Subscriptions ───────────────────────────────────────────────────────────

model SubscriptionPlan {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  price          Decimal              @db.Decimal(10, 2)
  currency       String               @default("INR")
  interval       SubscriptionInterval
  razorpayPlanId String?              @map("razorpay_plan_id")
  active         Boolean              @default(true)
  version        Int                  @default(1)
  effectiveFrom  DateTime             @default(now()) @map("effective_from")
  createdAt      DateTime             @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  userId                 String             @map("user_id") @db.Uuid
  planId                 String             @map("plan_id") @db.Uuid
  status                 SubscriptionStatus @default(active)
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  razorpaySubscriptionId String?            @map("razorpay_subscription_id")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("subscriptions")
}

// ─── Ads ─────────────────────────────────────────────────────────────────────

model AdCampaign {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  imageUrl  String   @map("image_url")
  linkUrl   String   @map("link_url")
  active    Boolean  @default(true)
  startsAt  DateTime @map("starts_at")
  endsAt    DateTime @map("ends_at")
  createdAt DateTime @default(now()) @map("created_at")

  placements AdPlacement[]

  @@map("ad_campaigns")
}

model AdPlacement {
  id         String          @id @default(uuid()) @db.Uuid
  campaignId String          @map("campaign_id") @db.Uuid
  type       AdPlacementType
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ad_placements")
}

// ─── Finance & Platform Config ─────────────────────────────────────────────────

model Settlement {
  id                 String           @id @default(uuid()) @db.Uuid
  publisherId        String           @map("publisher_id") @db.Uuid
  periodStart        DateTime         @map("period_start") @db.Date
  periodEnd          DateTime         @map("period_end") @db.Date
  grossAmount        Decimal          @map("gross_amount") @db.Decimal(12, 2)
  platformCommission Decimal          @map("platform_commission") @db.Decimal(12, 2)
  netAmount          Decimal          @map("net_amount") @db.Decimal(12, 2)
  status             SettlementStatus @default(pending)
  paidAt             DateTime?        @map("paid_at")
  createdAt          DateTime         @default(now()) @map("created_at")

  publisher Publisher @relation(fields: [publisherId], references: [id])
  orderItems OrderItem[]

  @@index([publisherId])
  @@map("settlements")
}

model PlatformConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("platform_config")
}

model CommissionRateHistory {
  id            String    @id @default(uuid()) @db.Uuid
  publisherId   String?   @map("publisher_id") @db.Uuid
  oldRate       Decimal?  @map("old_rate") @db.Decimal(5, 4)
  newRate       Decimal   @map("new_rate") @db.Decimal(5, 4)
  changedBy     String    @map("changed_by") @db.Uuid
  reason        String?
  effectiveFrom DateTime  @default(now()) @map("effective_from")
  createdAt     DateTime  @default(now()) @map("created_at")

  publisher Publisher? @relation(fields: [publisherId], references: [id])

  @@map("commission_rate_history")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id") @db.Uuid
  metadata     Json     @default("{}")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
